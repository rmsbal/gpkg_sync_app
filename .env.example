# Google Drive OAuth configuration
# Copy this file to .env and fill in your actual values.

GPKG_SYNC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GPKG_SYNC_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional: use a JSON file instead of the two values above.
# GPKG_SYNC_GOOGLE_CLIENT_JSON=/absolute/path/to/google_oauth_client.json
